# Do not commit real production values.
# Store real values in Google Secret Manager and inject them at deploy time.

NODE_ENV=production
PORT=8080
DATABASE_URL=postgres://music:<strong-password>@/<db-name>?host=/cloudsql/<project:region:instance>
JWT_SECRET=<random-256-bit-secret>

# CORS (optional, comma-separated list of allowed origins)
CORS_ORIGIN=https://frontend-<hash>-<region>.run.app

# Cloud Storage upload mode (recommended on Cloud Run)
GCS_UPLOAD_BUCKET=<gcs-bucket-name>
GCS_UPLOAD_PREFIX=uploads

# Frontend build-time API base URL
VITE_API_BASE_URL=https://backend-<hash>-<region>.run.app/api
